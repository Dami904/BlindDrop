# Copy to .env and fill in — never commit the real file.

# Sepolia JSON-RPC endpoint (Alchemy, Infura, etc.)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer private key (0x-prefixed). Use a throwaway/deploy-only key.
PRIVATE_KEY=0xyourprivatekey

# Optional: for `hardhat verify` on Sepolia Etherscan
ETHERSCAN_API_KEY=your_etherscan_api_key
